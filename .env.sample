# Multi-Agent Ops Assistant - Development Environment
# Copy this file to .env and fill in your values
#
# NOTE: When deploying with `azd up`, the variables marked [AUTO-SET] below
# are automatically populated from Bicep outputs. You only need to set them
# manually for local development without azd.

# =============================================================================
# Microsoft Foundry Configuration  [AUTO-SET by azd]
# =============================================================================
# Microsoft Foundry project endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=

# Model deployments
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
TRIAGE_MODEL_DEPLOYMENT=gpt-4o-mini

# =============================================================================
# Azure AI Search (Foundry IQ Knowledge Base)  [AUTO-SET by azd]
# =============================================================================
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
KNOWLEDGE_BASE_NAME=ops-assistant-kb
SEARCH_INDEX_NAME=ops-assistant-kb

# =============================================================================
# Azure SQL Database  [AUTO-SET by azd]
# =============================================================================
SQL_SERVER_FQDN=your-server.database.windows.net
SQL_DATABASE_NAME=ops-assistant-db

# =============================================================================
# Azure AI Content Safety (guardrails)  [AUTO-SET by azd]
# =============================================================================
# Optional: derived from project endpoint if not set
# CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# =============================================================================
# Azure OpenAI (for Foundry evaluators)  [AUTO-SET by azd]
# =============================================================================
# Optional: derived from project endpoint if not set
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# =============================================================================
# Azure Project Context (for evaluation logging)  [AUTO-SET by azd]
# =============================================================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-multi-agent-ops-assistant
AZURE_PROJECT_NAME=

# =============================================================================
# Store Configuration
# =============================================================================
DEFAULT_STORE_ID=STORE-001

# =============================================================================
# Foundry Tracing (OpenTelemetry → Application Insights)
# =============================================================================
# Sends distributed traces for every LLM call, tool execution, and agent run
# to the Application Insights resource linked to your Foundry project.
# View traces in Foundry portal → Tracing.
ENABLE_FOUNDRY_TRACING=true

# =============================================================================
# Traffic Simulator (generates realistic order flow in the background)
# =============================================================================
ENABLE_TRAFFIC_SIMULATOR=false
TRAFFIC_SIMULATOR_INTERVAL_SECS=60

# =============================================================================
# Logging Configuration
# =============================================================================
# Basic logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
