root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.{json,bicep}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{ps1,psm1,psd1}]
end_of_line = crlf

[Makefile]
indent_style = tab
